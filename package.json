{
  "name": "@coopah/copilot-auth",
  "version": "0.1.0",
  "description": "GitHub Copilot OAuth device flow + OpenAI-compatible client with auto-refreshing tokens",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./express": {
      "import": "./dist/express.js",
      "types": "./dist/express.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "express": ">=4"
  },
  "peerDependenciesMeta": {
    "express": { "optional": true }
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "typescript": "^5.8.0"
  },
  "license": "MIT",
  "author": "coopah",
  "keywords": [
    "github",
    "copilot",
    "oauth",
    "device-flow",
    "openai",
    "ai",
    "llm",
    "express"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coopah/copilot-auth.git"
  },
  "homepage": "https://github.com/coopah/copilot-auth#readme",
  "bugs": {
    "url": "https://github.com/coopah/copilot-auth/issues"
  },
  "engines": {
    "node": ">=18"
  }
}
